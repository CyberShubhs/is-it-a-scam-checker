generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Report {
  id               String   @id @default(cuid())
  type             String   // URL, PHONE, EMAIL
  value_raw        String
  value_normalised String
  notes            String?
  country          String   @default("AU")
  ip_hash          String
  user_agent_hash  String
  created_at       DateTime @default(now())

  // ── Entity-matching columns (added 2026-06) ────────────────────────────
  // These are nullable + back-fillable so the migration is purely additive
  // and NEVER destroys the 200+ existing community reports. They let the
  // scan-intel matcher find reports by the *specific* entity a user is
  // checking (a hostname, a registrable domain, an IP, an email/email-domain,
  // a normalised phone) instead of only the coarse `value_normalised`.
  //
  // Legacy rows have these as NULL; the matcher falls back to
  // `value_normalised` for those, so old reports still surface.
  entity_type        String? // url | domain | ip | email | phone (canonical)
  hostname           String? // full host for a URL, e.g. login.fake-bank.co
  registrable_domain String? // eTLD+1 for a URL/domain, e.g. fake-bank.co
  ip_address         String? // exact IP (v4/v6) when reporting an IP
  email_domain       String? // domain part of a reported email
  phone_normalised   String? // digits-only (E.164-ish) phone

  @@index([type, value_normalised])
  @@index([created_at])
  // Indexes that back the new entity-matching queries. Each is a cheap
  // equality lookup the matcher runs once per detected entity.
  @@index([hostname])
  @@index([registrable_domain])
  @@index([ip_address])
  @@index([email_domain])
  @@index([phone_normalised])
}

// Community votes on a reported scam, grouped by the normalised value (so all
// reports of e.g. "example-scam.com" share one vote tally). Two vote types:
//   HELPFUL  — "this report helped me / was useful"
//   SEEN_TOO — "I received / saw this same scam"
// A device (ip_hash + user_agent_hash) may cast each vote type once per value,
// enforced by the unique index — this blocks trivial duplicate inflation
// without storing any raw IP.
model ReportVote {
  id               String   @id @default(cuid())
  value_normalised String // grouping key — matches Report.value_normalised
  vote_type        String // HELPFUL | SEEN_TOO
  ip_hash          String
  user_agent_hash  String
  created_at       DateTime @default(now())

  // One vote of each type per device per value (dedupe guard).
  @@unique([value_normalised, vote_type, ip_hash])
  @@index([value_normalised, vote_type])
}

// Caches external threat-intelligence lookups (currently AbuseIPDB IP
// reputation) so we never re-hit a paid/rate-limited third-party API for the
// same value inside the cache window. Rows are keyed by (source, type, value)
// and expire after `expires_at`. The AbuseIPDB helper reads/writes this table
// with a 24-hour TTL — see src/lib/threat-intel/abuseipdb.ts.
model ThreatIntelCache {
  id         String   @id @default(cuid())
  type       String   // "IP" for now; future-proofed for DOMAIN/URL/etc.
  value      String   // the looked-up value, e.g. the IP address
  source     String   // "AbuseIPDB"
  payload_json String // raw provider response we surface to the UI (JSON)
  risk_score Int      @default(0) // distilled 0-100 risk for quick reads
  created_at DateTime @default(now())
  expires_at DateTime // cache entries past this are treated as stale

  // One live cache row per (source, type, value). The helper upserts on this
  // key, and prunes/ignores rows where expires_at < now().
  @@unique([source, type, value])
  @@index([expires_at])
}
