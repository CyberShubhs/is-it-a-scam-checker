# Defaults to ignore
# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
/dist

# misc
.DS_Store
*.pem
*.key
*.cer
*.sri

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# local env files
.env*.local
.env
.env.development
.env.test
.env.production

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# IDE
.vscode
.idea

# Secrets - paranoid mode
secrets.json
credentials.json
--template/

# Local tooling artefacts
/graphify-out/
.graphifyignore

# Private SEO working notes & internal AI prompts — operator-facing
# instructions that should not appear in the public repo.
SEO/claude/

# Source-health cache produced by scripts/check-blog-sources.mjs. Local-
# only optimisation — re-derived from network probes on the next run.
data/source-health-cache.json

# Generated client-side scanner assets (pdf.js worker, Tesseract worker/core/lang)
# Regenerated from node_modules by scripts/prepare-scan-assets.mjs on install/build.
/public/scan/
