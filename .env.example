# No environment variables are currently required for core features.
# If you add server-side logic, define keys here.
# EXAMPLE_KEY="placeholder"

# Required for AI blog post generation (auto-blog workflow)
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=""

# Google Analytics 4 Measurement ID (G-XXXXXXX). Leave blank to disable GA4.
NEXT_PUBLIC_GA_MEASUREMENT_ID=""

# Set to "true" to load GA4 outside production and surface gtag debug_mode
# (used with GA4 DebugView). Never enable in production.
NEXT_PUBLIC_GA_DEBUG=""
