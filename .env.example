# No environment variables are required for the core (browser-side) scanner.
# The keys below enable optional server-side features.

# AbuseIPDB IP-reputation lookups (server-side ONLY).
#   - Powers the "External IP reputation" results and /check-scam-ip.
#   - Get a free key at https://www.abuseipdb.com/account/api
#   - MUST be named exactly ABUSEIPDB_API_KEY (no NEXT_PUBLIC_ prefix — it is a
#     secret and must never reach the browser). If unset, IP checks degrade
#     gracefully to "External IP reputation check is not enabled."
ABUSEIPDB_API_KEY=""

# Per-deployment salt used to hash IPs for rate limiting + abuse controls.
# Set to any long random string in production. Never commit the real value.
IP_SALT=""

# Required for AI blog post generation (auto-blog workflow)
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=""

# Google Analytics 4 Measurement ID (G-XXXXXXX). Leave blank to disable GA4.
NEXT_PUBLIC_GA_MEASUREMENT_ID=""

# Set to "true" to load GA4 outside production and surface gtag debug_mode
# (used with GA4 DebugView). Never enable in production.
NEXT_PUBLIC_GA_DEBUG=""
